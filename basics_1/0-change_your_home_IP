#!/usr/bin/env bash
# /etc/hosts faylını 'Device or resource busy' xətası almadan yeniləyən skript

# 1. Mövcud hosts faylının kontentini oxuyub, dəyişiklikləri müvəqqəti fayla yazırıq
sed 's/127.0.0.1\s*localhost/127.0.0.2 localhost/g' /etc/hosts > /tmp/hosts.tmp

# 2. Əgər facebook.com yoxdursa əlavə edirik, varsa IP-sini dəyişirik
if ! grep -q "facebook.com" /tmp/hosts.tmp; then
    echo "8.8.8.8 facebook.com" >> /tmp/hosts.tmp
else
    sed -i 's/.*facebook.com/8.8.8.8 facebook.com/g' /tmp/hosts.tmp
fi
